generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  password        String
  role            Role      @default(USER)
  pixKey          String?
  createdAt       DateTime  @default(now())
  orders          Order[]
  listings        Listing[]
  reviewsGiven    Review[]  @relation("ReviewGiver")
  reviewsReceived Review[]  @relation("ReviewReceiver")
}

enum Role {
  USER
  ADMIN
}

model Product {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  description    String
  suggestedPrice Decimal       @db.Decimal(10, 2)
  image          String
  category       String
  rarity         String        @default("Common")
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  listingItems   ListingItem[]
}

model Listing {
  id         String        @id @default(cuid())
  sellerId   String
  seller     User          @relation(fields: [sellerId], references: [id])
  items      ListingItem[]
  status     ListingStatus @default(PENDENTE_ENTREGA)
  adminNotes String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

enum ListingStatus {
  PENDENTE_ENTREGA
  DISPONIVEL
  PARCIALMENTE_VENDIDO
  VENDIDO
  CANCELAMENTO_SOLICITADO
  CANCELADO
}

model ListingItem {
  id         String            @id @default(cuid())
  listingId  String
  listing    Listing           @relation(fields: [listingId], references: [id])
  productId  String
  product    Product           @relation(fields: [productId], references: [id])
  quantity   Int
  price      Decimal           @db.Decimal(10, 2)
  status     ListingItemStatus @default(DISPONIVEL)
  orderItems OrderItem[]
  createdAt  DateTime          @default(now())
}

enum ListingItemStatus {
  DISPONIVEL
  VENDIDO
}

model Order {
  id         String      @id @default(cuid())
  buyerId    String
  buyer      User        @relation(fields: [buyerId], references: [id])
  items      OrderItem[]
  total      Decimal     @db.Decimal(10, 2)
  commission Decimal     @db.Decimal(10, 2)
  status     OrderStatus @default(PENDENTE)
  pixCode    String?
  pixQrCode  String?
  pixExpires DateTime?
  paymentId  String?
  sellerPaid Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum OrderStatus {
  PENDENTE
  PAGO
  ENTREGUE
  CANCELADO
}

model OrderItem {
  id            String      @id @default(cuid())
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id])
  listingItemId String
  listingItem   ListingItem @relation(fields: [listingItemId], references: [id])
  quantity      Int
  price         Decimal     @db.Decimal(10, 2)
}

model Review {
  id         String     @id @default(cuid())
  giverId    String
  giver      User       @relation("ReviewGiver", fields: [giverId], references: [id])
  receiverId String
  receiver   User       @relation("ReviewReceiver", fields: [receiverId], references: [id])
  orderId    String
  rating     Int
  comment    String?
  type       ReviewType
  createdAt  DateTime   @default(now())
}

enum ReviewType {
  COMPRADOR_PARA_VENDEDOR
  VENDEDOR_PARA_COMPRADOR
}
