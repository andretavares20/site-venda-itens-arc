generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  password        String
  cpf             String?         @unique
  role            Role            @default(USER)
  tier            UserTier?
  pixKey               String?
  asaasId              String?
  emailVerified        DateTime?
  verificationToken    String?     @unique
  verificationExpires  DateTime?
  discordId            String?
  adminNotifSeenAt     DateTime?
  createdAt            DateTime    @default(now())
  orders          Order[]
  listings        Listing[]
  stocks          Stock[]
  reviewsGiven         Review[]            @relation("ReviewGiver")
  reviewsReceived      Review[]            @relation("ReviewReceiver")
  trades               Trade[]
  proposals            TradeProposal[]
  coupon               Coupon?
  notifications        Notification[]
  encomendas           Encomenda[]
  encomendaProposals   EncomendaProposal[]
}

enum Role {
  USER
  ADMIN
}

enum UserTier {
  PARTNER
  VERIFIED_TRADER
  ELITE_RIDER
}

model Product {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String
  suggestedPrice  Decimal         @db.Decimal(10, 2)
  image           String
  category        String
  rarity          String          @default("Common")
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  listingItems    ListingItem[]
  stocks          Stock[]
  tradeOfferItems TradeOfferItem[]
  tradeWantItems  TradeWantItem[]
  proposalItems   ProposalItem[]
  encomendas      Encomenda[]
}

model Listing {
  id         String        @id @default(cuid())
  sellerId   String
  seller     User          @relation(fields: [sellerId], references: [id])
  items      ListingItem[]
  stocks     Stock[]
  status     ListingStatus @default(PENDENTE_ENTREGA)
  adminNotes String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

enum ListingStatus {
  PENDENTE_ENTREGA
  DISPONIVEL
  PARCIALMENTE_VENDIDO
  VENDIDO
  CANCELAMENTO_SOLICITADO
  CANCELADO
}

model ListingItem {
  id         String            @id @default(cuid())
  listingId  String
  listing    Listing           @relation(fields: [listingId], references: [id])
  productId  String
  product    Product           @relation(fields: [productId], references: [id])
  quantity   Int
  price      Decimal           @db.Decimal(10, 2)
  status     ListingItemStatus @default(DISPONIVEL)
  createdAt  DateTime          @default(now())
}

enum ListingItemStatus {
  DISPONIVEL
  VENDIDO
}

model Order {
  id               String      @id @default(cuid())
  buyerId          String
  buyer            User        @relation(fields: [buyerId], references: [id])
  items            OrderItem[]
  total            Decimal     @db.Decimal(10, 2)
  commission       Decimal     @db.Decimal(10, 2)
  status           OrderStatus @default(PENDENTE)
  pixCode          String?
  pixQrCode        String?
  pixExpires       DateTime?
  paymentId        String?
  sellerPaid              Boolean            @default(false)
  couponCode              String?
  couponDiscount          Decimal?           @db.Decimal(10, 4)
  riderCommission         Decimal?           @db.Decimal(10, 4)
  riderPaid               Boolean            @default(false)
  deliveredAt             DateTime?
  encomendaProposalId     String?            @unique
  encomendaProposal       EncomendaProposal? @relation(fields: [encomendaProposalId], references: [id])
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
}

enum OrderStatus {
  PENDENTE
  PAGO
  ENTREGUE
  CANCELADO
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  stockId   String?
  stock     Stock?  @relation(fields: [stockId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
}

// ─── Estoque ─────────────────────────────────────────────────────

model Stock {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id])
  sellerId   String
  seller     User        @relation(fields: [sellerId], references: [id])
  listingId  String?
  listing    Listing?    @relation(fields: [listingId], references: [id])
  quantity   Int         @default(0)
  price      Decimal     @db.Decimal(10, 2)
  active     Boolean     @default(true)
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([productId, sellerId])
}

// ─── Sistema de Trocas ───────────────────────────────────────────

model Trade {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id])
  offerItems TradeOfferItem[]
  wantItems  TradeWantItem[]  // vazio = aceita qualquer proposta
  proposals  TradeProposal[]
  status     TradeStatus     @default(ABERTA)
  note       String?         // observação opcional do dono
  expiresAt  DateTime?       // 24h após proposta aceita
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

enum TradeStatus {
  ABERTA
  AGUARDANDO_CONFIRMACAO
  AGUARDANDO_RECOLHIMENTO
  AGUARDANDO_ENTREGA
  CONCLUIDA
  CANCELADA
  COM_RECLAMACAO
}

model TradeOfferItem {
  id        String  @id @default(cuid())
  tradeId   String
  trade     Trade   @relation(fields: [tradeId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
}

model TradeWantItem {
  id        String  @id @default(cuid())
  tradeId   String
  trade     Trade   @relation(fields: [tradeId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
}

model TradeProposal {
  id                String         @id @default(cuid())
  tradeId           String
  trade             Trade          @relation(fields: [tradeId], references: [id])
  proposerId        String
  proposer          User           @relation(fields: [proposerId], references: [id])
  offerItems        ProposalItem[]
  status            ProposalStatus @default(PENDENTE)
  ownerConfirmed    Boolean        @default(false)
  proposerConfirmed Boolean        @default(false)
  note              String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

enum ProposalStatus {
  PENDENTE
  ACEITA
  RECUSADA
  CANCELADA
  CONCLUIDA
  COM_RECLAMACAO
}

model ProposalItem {
  id         String        @id @default(cuid())
  proposalId String
  proposal   TradeProposal @relation(fields: [proposalId], references: [id])
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  quantity   Int           @default(1)
}

// ─── Avaliações ─────────────────────────────────────────────────

model Review {
  id         String     @id @default(cuid())
  giverId    String
  giver      User       @relation("ReviewGiver", fields: [giverId], references: [id])
  receiverId String
  receiver   User       @relation("ReviewReceiver", fields: [receiverId], references: [id])
  orderId    String?
  tradeId    String?
  rating     Int
  comment    String?
  type       ReviewType
  createdAt  DateTime   @default(now())
}

enum ReviewType {
  COMPRADOR_PARA_VENDEDOR
  VENDEDOR_PARA_COMPRADOR
  TROCA
}

// ─── Cupons de Elite Riders ──────────────────────────────────────

// ─── Encomendas ──────────────────────────────────────────────────

model Encomenda {
  id        String              @id @default(cuid())
  buyerId   String
  buyer     User                @relation(fields: [buyerId], references: [id])
  productId String
  product   Product             @relation(fields: [productId], references: [id])
  quantity  Int
  maxPrice  Decimal?            @db.Decimal(10, 2)
  note      String?
  status    EncomendaStatus     @default(ABERTA)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  proposals EncomendaProposal[]
}

enum EncomendaStatus {
  ABERTA
  ACEITA
  PAGA
  CONCLUIDA
  CANCELADA
}

model EncomendaProposal {
  id          String                  @id @default(cuid())
  encomendaId String
  encomenda   Encomenda               @relation(fields: [encomendaId], references: [id])
  sellerId    String
  seller      User                    @relation(fields: [sellerId], references: [id])
  price       Decimal                 @db.Decimal(10, 2)
  note        String?
  status      EncomendaProposalStatus @default(PENDENTE)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  order       Order?
}

enum EncomendaProposalStatus {
  PENDENTE
  ACEITA
  RECUSADA
  CANCELADA
}

// ─── Notificações ────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Coupon {
  id                String   @id @default(cuid())
  code              String   @unique
  discountPercent   Float    @default(0)
  commissionPercent Float    @default(5)
  riderId           String   @unique
  rider             User     @relation(fields: [riderId], references: [id])
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
}
