# ──────────────────────────────────────────────
# TEMPLATE — copie para .env.development (local) ou configure no painel da Vercel (produção)
# ──────────────────────────────────────────────

# Banco de dados — Neon PostgreSQL
# Crie em: https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# NextAuth
# Gere o secret com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="seu_secret_aqui"
NEXTAUTH_URL="http://localhost:3000"           # desenvolvimento
# NEXTAUTH_URL="https://seudominio.com.br"    # produção

# Mercado Pago
# DESENVOLVIMENTO: Access Token de TESTE (começa com TEST-)
# PRODUÇÃO:        Access Token de PRODUÇÃO (começa com APP_USR-)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN="TEST-ou-APP_USR-seu_token_aqui"

# URL pública do site (usada nos webhooks do Mercado Pago)
NEXT_PUBLIC_URL="http://localhost:3000"        # desenvolvimento
# NEXT_PUBLIC_URL="https://seudominio.com.br" # produção
